{
  "name": "qqbot",
  "version": "0.1.0",
  "private": true,
  "description": "QQ group AI chat bot powered by Koishi + OneBot on Fedora/Podman",
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json",
    "dev": "pnpm start",
    "docs:dev": "vitepress dev web",
    "docs:build": "vitepress build web",
    "docs:preview": "vitepress preview web",
    "start": "pnpm build && pnpm exec koishi start koishi.yml",
    "smoke:start": "bash ./scripts/smoke-koishi-start.sh",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@koishijs/plugin-commands": "^3.5.5",
    "@koishijs/plugin-database-sqlite": "^4.7.0",
    "@koishijs/plugin-http": "^0.6.3",
    "@koishijs/plugin-proxy-agent": "^0.3.3",
    "@koishijs/plugin-server": "^3.2.7",
    "cron-parser": "^4.9.0",
    "koishi": "^4.18.10",
    "koishi-plugin-adapter-onebot": "^6.8.0",
    "koishi-plugin-chatluna": "1.3.25",
    "koishi-plugin-chatluna-deepseek-adapter": "^1.3.10",
    "koishi-plugin-chatluna-long-memory": "^1.3.1",
    "koishi-plugin-chatluna-mcp-client": "^1.3.3",
    "koishi-plugin-chatluna-plugin-common": "^1.3.4",
    "koishi-plugin-chatluna-search-service": "^1.3.3",
    "koishi-plugin-chatluna-storage-service": "^1.0.3",
    "koishi-plugin-chatluna-vector-store-service": "^1.3.2",
    "koishi-plugin-cron": "^3.1.0",
    "koishi-plugin-puppeteer": "^3.9.0"
  },
  "devDependencies": {
    "@types/node": "^25.3.0",
    "typescript": "^5.9.3",
    "vitepress": "^1.6.4",
    "vitest": "^4.0.18"
  }
}
