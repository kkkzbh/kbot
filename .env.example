# Core Bot
BOT_OWNER_QQ=2219854433
ONEBOT_SELF_ID=100000001
ONEBOT_WS_ENDPOINT=ws://127.0.0.1:3001
ONEBOT_TOKEN=
KOISHI_HOST=0.0.0.0
KOISHI_PORT=5140
SQLITE_PATH=./data/koishi.db
CHATLUNA_COMMAND_AUTHORITY=3

# Legacy Group Chat Policy (rollback only)
CHAT_ENABLED_GROUPS=123456789,987654321
CHAT_TRIGGER_MODE=mention
CHAT_MAX_CONTEXT_TURNS=8
CHAT_TIMEOUT_MS=20000
CHAT_USER_COOLDOWN_MS=8000
CHAT_GROUP_QPS_LIMIT=1
# 单行提示词（短 prompt 用这个）
CHAT_SYSTEM_PROMPT=你是群聊助手。回答简洁、准确、中文优先。
# 多行/超长提示词（推荐）：填文件路径，支持相对路径（相对当前工作目录）或绝对路径
CHAT_SYSTEM_PROMPT_FILE=

# OpenAI-compatible API (used by ChatLuna DeepSeek adapter)
OPENAI_BASE_URL=https://api.deepseek.com/v1
OPENAI_API_KEY=sk-xxxx
OPENAI_MODEL=deepseek/deepseek-chat

# LLBot official docker stack (pmhq + llbot)
PMHQ_IMAGE=docker.io/linyuchen/pmhq
PMHQ_TAG=latest
LLBOT_IMAGE=docker.io/linyuchen/llbot
LLBOT_TAG=latest
ENABLE_HEADLESS=false
AUTO_LOGIN_QQ=
LLONEBOT_WEBUI_PORT=3080
LLONEBOT_WS_PORT=3001
TZ=Asia/Shanghai
